# Copy this file to .env (same folder) and fill in your Supabase project's
# values: Dashboard → Project Settings → API.
#
# The anon key is safe to expose in the client bundle — it has no special
# privileges on its own. Row Level Security policies (supabase/schema.sql)
# are what actually control access.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
